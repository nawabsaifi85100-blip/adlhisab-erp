{
  "name": "adlhisab-erp",
  "version": "2.0.0",
  "description": "AdlHisab - Complete Enterprise Resource Planning System",
  "main": "src/server.js",
  "homepage": "./",
  "proxy": "http://localhost:5000",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "server": "node src/server.js",
    "build-exe": "electron-builder --win --publish never",
    "build-apk": "cd mobile && ./gradlew assembleRelease",
    "test": "jest",
    "lint": "eslint src/",
    "docker-build": "docker build -t adlhisab-erp:latest .",
    "docker-run": "docker run -p 5000:5000 -p 3000:3000 adlhisab-erp:latest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.4.0",
    "express-validator": "^7.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "eslint": "^8.41.0",
    "electron": "^latest",
    "electron-builder": "^latest"
  }
}
